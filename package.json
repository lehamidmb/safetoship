{
  "name": "shipverdict",
  "version": "0.1.0",
  "description": "Vibe code with peace of mind: a local pre-launch gate for exposed keys, Supabase gaps, cost abuse, and launch compliance.",
  "type": "module",
  "bin": {
    "shipverdict": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "action.yml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "check": "npm run build && npm test",
    "prepack": "npm run build"
  },
  "keywords": [
    "security",
    "supabase",
    "nextjs",
    "vibe-coding",
    "ai-generated-code",
    "launch-gate",
    "compliance",
    "privacy-policy",
    "cost-abuse",
    "cli",
    "github-action"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^14.0.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
